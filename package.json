{
	"name": "untab-studio",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "cross-env NODE_OPTIONS=\"--disable-warning=DEP0205 --localstorage-file=.next/node-localstorage\" next dev --turbopack -p 3000",
		"build:profile": "cross-env NEXT_BUILD_PROFILE=true next build",
		"build": "next build",
		"start": "next start",
		"lint": "biome lint --max-diagnostics=200",
		"lint:fix": "biome lint --write --max-diagnostics=200",
		"format": "biome format --write .",
		"lighthouse": "bunx @unlighthouse/cli --site http://localhost:3000",
		"typecheck": "tsc --noEmit --incremental false",
		"analyze": "next experimental-analyze",
		"seed:import": "sanity dataset import sanity/seed/projects.ndjson production --replace",
		"prepare": "husky",
		"email": "email dev"
	},
	"dependencies": {
		"@arcjet/inspect": "^1.7.0",
		"@arcjet/next": "^1.7.0",
		"@gsap/react": "^2.1.2",
		"@hugeicons/core-free-icons": "^4.2.2",
		"@hugeicons/react": "^1.1.9",
		"@portabletext/react": "^6.2.0",
		"@sanity/icons": "^3.8.0",
		"@sanity/image-url": "^2.1.1",
		"@sanity/ui": "^3.3.5",
		"@sanity/vision": "^5.31.1",
		"clsx": "^2.1.1",
		"gsap": "^3.15.0",
		"lenis": "^1.3.25",
		"next": "16.2.10",
		"next-sanity": "^13.1.1",
		"next-themes": "^0.4.6",
		"posthog-js": "^1.396.9",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"resend": "^6.17.1",
		"sanity": "^5.31.1",
		"shadcn": "^4.13.0",
		"tailwind-merge": "^3.6.0",
		"tempus": "1.0.0-dev.17",
		"tw-animate-css": "^1.4.0",
		"vanilla-cookieconsent": "^3.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@react-email/components": "^1.0.12",
		"@react-email/preview-server": "5.2.10",
		"@react-email/ui": "6.5.0",
		"@svgr/webpack": "^8.1.0",
		"@tailwindcss/postcss": "^4.3.2",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.4",
		"@types/react": "19.2.16",
		"@types/react-dom": "^19.2.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"cross-env": "^10.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"react-email": "^6.6.6",
		"tailwindcss": "^4.3.2",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx}": [
			"biome lint --write --no-errors-on-unmatched",
			"biome format --write --no-errors-on-unmatched"
		]
	}
}
