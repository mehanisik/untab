{
	"name": "untab-studio",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build:analyze": "cross-env SOURCE_MAPS=true bun run build && source-map-explorer .next/static/chunks/*.js",
		"build:profile": "cross-env NEXT_BUILD_PROFILE=true next build",
		"build": "next build",
		"start": "next start",
		"lint": "biome lint --max-diagnostics=200",
		"lint:fix": "biome lint --write --max-diagnostics=200",
		"format": "biome format --write .",
		"lighthouse": "bunx @unlighthouse/cli --site http://localhost:3000",
		"typecheck": "tsc --noEmit --incremental false",
		"analyze": "cross-env ANALYZE=true next build",
		"seed:import": "sanity dataset import sanity/seed/projects.ndjson production --replace",
		"prepare": "husky",
		"email": "email dev"
	},
	"dependencies": {
		"@arcjet/inspect": "^1.0.0",
		"@arcjet/next": "^1.0.0",
		"@base-ui/react": "^1.5.0",
		"@gsap/react": "^2.1.2",
		"@hugeicons/core-free-icons": "^3.1.1",
		"@hugeicons/react": "^1.1.4",
		"@portabletext/react": "^6.0.2",
		"@posthog/next": "^0.4.62",
		"@sanity/icons": "^3.7.4",
		"@sanity/image-url": "^2.1.1",
		"@sanity/vision": "^5.28.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"embla-carousel-react": "^8.6.0",
		"gsap": "^3.15.0",
		"hamo": "1.0.0-dev.13",
		"input-otp": "^1.4.2",
		"lenis": "^1.3.23",
		"lucide-react": "^0.562.0",
		"next": "16.2.7",
		"next-sanity": "^13.0.10",
		"next-themes": "^0.4.6",
		"posthog-js": "^1.376.0",
		"react": "19.2.7",
		"react-day-picker": "^9.13.0",
		"react-dom": "19.2.7",
		"react-resizable-panels": "^3.0.6",
		"recharts": "2.15.4",
		"resend": "^6.8.0",
		"sanity": "^5.28.0",
		"shadcn": "^3.7.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.0",
		"tempus": "1.0.0-dev.17",
		"tw-animate-css": "^1.4.0",
		"vanilla-cookieconsent": "^3.1.0",
		"vaul": "^1.1.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@next/bundle-analyzer": "16.2.7",
		"@react-email/components": "^1.0.6",
		"@react-email/preview-server": "5.1.0",
		"@svgr/webpack": "^8.1.0",
		"@tailwindcss/postcss": "^4.3.0",
		"@types/bun": "^1.3.6",
		"@types/node": "^25.9.1",
		"@types/react": "19.2.16",
		"@types/react-dom": "^19.2.3",
		"@types/uuid": "^11.0.0",
		"babel-plugin-react-compiler": "^1.0.0",
		"cross-env": "^10.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"react-email": "^5.2.5",
		"tailwindcss": "^4.3.0",
		"typescript": "^5.9.3",
		"uuid": "^13.0.0"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx}": [
			"biome lint --write --no-errors-on-unmatched",
			"biome format --write --no-errors-on-unmatched"
		]
	}
}
